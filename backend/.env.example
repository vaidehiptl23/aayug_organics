# Copy this file to .env and fill in your values
# Database: MySQL on Aiven (free hosted — https://aiven.io/free)

NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ── MySQL (Aiven) ─────────────────────────────────────────────────────────────
# Get from: https://aiven.io → Your MySQL Service → Overview → Service URI
DATABASE_URL="mysql://avnadmin:PASSWORD@HOST.aivencloud.com:PORT/defaultdb?ssl-mode=REQUIRED"

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Free: https://upstash.com
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-random-32-char-string
JWT_REFRESH_SECRET=change-this-different-random-32-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_EMAIL_SECRET=change-this-email-secret
JWT_EMAIL_EXPIRY=24h
JWT_RESET_SECRET=change-this-reset-secret
JWT_RESET_EXPIRY=1h

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=Aayug Organics <noreply@aayugorganics.com>

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Business ──────────────────────────────────────────────────────────────────
FREE_SHIPPING_THRESHOLD=999
SHIPPING_CHARGE=99
TAX_RATE=0.18
BCRYPT_ROUNDS=12
