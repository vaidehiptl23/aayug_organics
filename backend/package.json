
{
  "name": "aayug-organics-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Aayug Organics e-commerce platform",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && prisma migrate deploy",
    "start": "npx ts-node --transpile-only src/server.ts",
    "seed": "ts-node prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force"
  },
  "keywords": ["ecommerce", "nodejs", "express", "typescript", "postgresql"],
  "author": "Aayug Organics",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.14.0",
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-async-errors": "3.1.1",
    "express-rate-limit": "7.3.1",
    "helmet": "7.1.0",
    "http-status-codes": "2.3.0",
    "ioredis": "5.3.2",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "nodemailer": "6.9.14",
    "razorpay": "2.9.2",
    "slugify": "1.6.6",
    "ts-node": "10.9.2",
    "typescript": "5.5.3",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "uuid": "10.0.0",
    "winston": "3.13.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.7.5",
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.9",
    "@types/multer": "1.4.11",
    "@types/nodemailer": "6.4.15",
    "@types/node": "20.14.10",
    "@types/supertest": "6.0.2",
    "@types/swagger-jsdoc": "6.0.4",
    "@types/swagger-ui-express": "4.1.6",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "prisma": "5.14.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src/tests"],
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/tests/**",
      "!src/server.ts",
      "!src/swagger/**"
    ],
    "setupFilesAfterFramework": [],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
